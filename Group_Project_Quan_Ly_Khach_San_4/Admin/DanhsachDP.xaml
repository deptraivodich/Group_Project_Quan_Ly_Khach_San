<Page x:Class="Group_Project_Quan_Ly_Khach_San_Nhom4.Admin.DanhsachDP"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Danh Sách Đặt Phòng"
      Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ DANH SÁCH ĐẶT PHÒNG"
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#0F172A" CornerRadius="15" BorderBrush="#334155" BorderThickness="1" Padding="5">
            <DataGrid x:Name="BookingDataGrid" 
                      ItemsSource="{Binding Bookings}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      Background="Transparent" 
                      Foreground="White" 
                      BorderThickness="0" 
                      RowHeight="42"
                      AlternatingRowBackground="#1E293B" 
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#2A3445" 
                      VerticalGridLinesBrush="#2A3445">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#0B1220"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,6"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Khách Hàng" Binding="{Binding CustomerName}" Width="*"/>

                    <DataGridTextColumn Header="Số Phòng" Binding="{Binding RoomType}" Width="100"/>

                    <DataGridTextColumn Header="Ngày Nhận" Binding="{Binding CheckIn, StringFormat=\{0:dd/MM/yyyy\}}" Width="130"/>

                    <DataGridTextColumn Header="Ngày Trả" Binding="{Binding CheckOut, StringFormat=\{0:dd/MM/yyyy\}}" Width="130"/>

                    <DataGridTextColumn Header="Số Đêm" Binding="{Binding Nights}" Width="80"/>

                    <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TotalPrice, StringFormat=N0}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Sửa" Width="120" Height="40" Margin="5" Background="#555555" Foreground="White" Click="BtnSua_Click"/>
            <Button Content="Xóa" Width="120" Height="40" Margin="5" Background="#DC2626" Foreground="White" Click="BtnXoa_Click"/>

            <TextBox x:Name="txtSearch" Width="200" Height="40" Margin="20,0,5,0" VerticalContentAlignment="Center" Padding="10,0" Background="#1F2937" Foreground="White"/>
            <Button Content="Tìm" Width="80" Height="40" Margin="5" Background="#2563EB" Foreground="White" Click="BtnSearch_Click"/>
            <Button Content="Reset" Width="80" Height="40" Margin="5" Background="#4B5563" Foreground="White" Click="BtnReset_Click"/>
        </StackPanel>
    </Grid>
</Page>