<Window x:Class="Group_Project_Quan_Ly_Khach_San_Nhom4.Admin.NhanVienForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông Tin Nhân Viên"
        Height="460"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Họ tên -->
        <StackPanel Margin="0,10">
            <TextBlock Text="Họ tên"
                       Foreground="White"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtHoTen"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     Padding="8"/>
        </StackPanel>

        <!-- Chức vụ -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Chức vụ"
                       Foreground="White"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtChucVu"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     Padding="8"/>
        </StackPanel>

        <!-- SĐT -->
        <StackPanel Grid.Row="2" Margin="0,10">
            <TextBlock Text="SĐT"
                       Foreground="White"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtSDT"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     Padding="8"/>
        </StackPanel>

        <!-- Lương -->
        <StackPanel Grid.Row="3" Margin="0,10">
            <TextBlock Text="Lương"
                       Foreground="White"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtLuong"
                     Height="35"
                     Background="#1E293B"
                     Foreground="White"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     Padding="8"/>
        </StackPanel>

        <!-- Button -->
        <Button Grid.Row="4"
                Content="Lưu"
                Height="45"
                Margin="0,25,0,0"
                Background="#555555"
                Foreground="White"
                FontWeight="SemiBold"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnSave_Click"/>
    </Grid>
</Window>
