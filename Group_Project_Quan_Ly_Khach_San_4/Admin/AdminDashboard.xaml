<Window x:Class="Group_Project_Quan_Ly_Khach_San_Nhom4.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="Admin Dashboard">

    <!-- ================= STYLE ================= -->
    <Window.Resources>

        <!-- Premium Button -->
        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="14"
                                Padding="12"
                                Background="#2D2D2D">

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                                  ShadowDepth="3"
                                                  Opacity="0.4"/>
                            </Border.Effect>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">

                                <TextBlock Text="{TemplateBinding Tag}"
                                           FontSize="16"
                                           Margin="0,0,8,0"/>

                                <ContentPresenter VerticalAlignment="Center"/>

                            </StackPanel>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3A3A3A"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ================= GIAO DIỆN ================= -->
    <Grid>

        <!-- BACKGROUND -->
        <Image Source="pack://application:,,,/Dat_Phong/hotel.jpg"
           Stretch="UniformToFill"/>

        <!-- OVERLAY -->
        <Border Background="#66000000"/>
        <Grid Margin="40">

            <Grid.ColumnDefinitions>
                <!-- Tăng width để không bị che chữ -->
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= SIDEBAR ================= -->
            <Border Background="#CC1E1E1E"
                    CornerRadius="20"
                    Padding="25"
                    Margin="0,0,25,0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="30"
                                      ShadowDepth="5"
                                      Opacity="0.5"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="ADMIN DASHBOARD"
                               FontSize="22"
                               TextWrapping="Wrap"
                               Foreground="#E5E7EB"
                               FontWeight="Bold"
                               Margin="0,0,0,40"/>

                    <Button Content="Quản Lý Nhân Viên"
                            Tag="👨‍💼"
                            Style="{StaticResource PremiumButton}"
                            Click="BtnNhanVien_Click"/>

                    <Button Content="Danh Sách Đặt Phòng"
                            Tag="🛏"
                            Style="{StaticResource PremiumButton}"
                            Click="BtnDatPhong_Click"/>

                    <Button Content="Thống Kê Doanh Thu"
                            Tag="📊"
                            Style="{StaticResource PremiumButton}"
                            Click="BtnThongKe_Click"/>

                </StackPanel>
            </Border>

            <!-- ================= CONTENT ================= -->
            <Border Grid.Column="1"
                    Background="#1F2937"
                    BorderBrush="#2D3748"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="25"
                                      ShadowDepth="5"
                                      Opacity="0.3"/>
                </Border.Effect>

                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"/>

            </Border>

        </Grid>

    </Grid>
</Window>