<Page x:Class="Group_Project_Quan_Ly_Khach_San_Nhom4.Admin.QuanLyNhanVien"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>

        <!-- Style Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="QUẢN LÝ NHÂN VIÊN"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- ================= DATAGRID ================= -->
        <DataGrid x:Name="NhanVienDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  Background="#0F172A"
                  Foreground="White"
                  BorderBrush="Black"
                  BorderThickness="1"
                  RowHeight="42"
                  AlternatingRowBackground="#1E293B"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="Black"
                  VerticalGridLinesBrush="Black">

            <!-- HEADER STYLE -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#0B1220"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="10,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- CELL STYLE -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </DataGrid.CellStyle>

            <!-- ROW STYLE -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="#172033"/>
                    <Setter Property="Foreground" Value="White"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#233044"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2563EB"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- COLUMNS -->
            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="70"/>

                <DataGridTextColumn Header="Họ Tên"
                                    Binding="{Binding HoTen}"
                                    Width="*"/>

                <DataGridTextColumn Header="Chức Vụ"
                                    Binding="{Binding ChucVu}"
                                    Width="150"/>

                <DataGridTextColumn Header="SĐT"
                                    Binding="{Binding SoDienThoai}"
                                    Width="130"/>

                <DataGridTextColumn Header="Lương"
                                    Binding="{Binding Luong, StringFormat=N0}"
                                    Width="130"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Thêm"
                    Style="{StaticResource PrimaryButton}"
                    Background="#555555"
                    Click="BtnThem_Click"/>

            <Button Content="Sửa"
                    Style="{StaticResource PrimaryButton}"
                    Background="#555555"
                    Click="BtnSua_Click"/>

            <Button Content="Làm mới"
                    Style="{StaticResource PrimaryButton}"
                    Background="#555555"
                    Click="BtnRefresh_Click"/>

            <Button Content="Xóa"
                    Style="{StaticResource PrimaryButton}"
                    Background="#DC2626"
                    Click="BtnXoa_Click"/>

        </StackPanel>

    </Grid>
</Page>
