<Window x:Class="Group_Project_Quan_Ly_Khach_San_4.LE_TAN.DangKy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Ký Tài Khoản" Height="550" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid>
        <Image Source="pack://application:,,,/Dat_Phong/hotel.jpg" Stretch="UniformToFill"/>
        <Border Background="#99000000"/>

        <StackPanel Width="340" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="TẠO TÀI KHOẢN" 
                       FontSize="26" FontWeight="Bold" Foreground="White" 
                       HorizontalAlignment="Center" Margin="0,0,0,25">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="Tên đăng nhập" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="38" Margin="0,0,0,12" Padding="10,0" 
                     VerticalContentAlignment="Center" Background="#40FFFFFF" Foreground="White"
                     BorderBrush="#80FFFFFF"/>

            <TextBlock Text="Mật khẩu" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="38" Margin="0,0,0,12" Padding="10,0" 
                         VerticalContentAlignment="Center" Background="#40FFFFFF" Foreground="White"
                         BorderBrush="#80FFFFFF"/>

            <TextBlock Text="Xác nhận mật khẩu" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtConfirmPassword" Height="38" Margin="0,0,0,12" Padding="10,0" 
                         VerticalContentAlignment="Center" Background="#40FFFFFF" Foreground="White"
                         BorderBrush="#80FFFFFF"/>

            <TextBlock Text="Vai trò hệ thống" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbRole" Height="38" Margin="0,0,0,25" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Lễ tân" IsSelected="True"/>
                <ComboBoxItem Content="Admin"/>
            </ComboBox>

            <Button Content="ĐĂNG KÝ NGAY" Height="45" FontSize="16" FontWeight="Bold" 
                    Foreground="White" Background="#27AE60" BorderThickness="0" 
                    Cursor="Hand" Click="BtnRegister_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Quay lại Đăng nhập" Background="Transparent" Foreground="White" 
                    BorderThickness="0" Margin="0,15,0,0" Cursor="Hand" Click="BtnBack_Click"/>

        </StackPanel>
    </Grid>
</Window>