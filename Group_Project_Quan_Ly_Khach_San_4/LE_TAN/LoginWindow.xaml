<Window x:Class="Group_Project_Quan_Ly_Khach_San_4.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Nhập Hệ Thống" Height="500" Width="400" 
        WindowStartupLocation="CenterScreen" Background="#F5F6FA" ResizeMode="NoResize">
    <Grid>
        <Image Source="pack://application:,,,/Dat_Phong/hotel.jpg"
               Stretch="UniformToFill"/>

        <Border Background="#99000000"/>

        <StackPanel Width="320"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <TextBlock Text="ĐĂNG NHẬP"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="Tên đăng nhập"
                       Foreground="White"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername"
                     Height="40"
                     Margin="0,0,0,15"
                     Padding="10,0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     Background="#40FFFFFF" 
                     Foreground="White"
                     BorderThickness="1"
                     BorderBrush="#80FFFFFF"/>

            <TextBlock Text="Mật khẩu"
                       Foreground="White"
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword"
                         Height="40"
                         Margin="0,0,0,20"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Background="#40FFFFFF"
                         Foreground="White"
                         BorderThickness="1"
                         BorderBrush="#80FFFFFF"/>

            <Button Content="ĐĂNG NHẬP"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#E67E22"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnLogin_Click"
                    Margin="0,0,0,10">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="ĐĂNG KÝ"
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#E67E22"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ShowRegister_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock x:Name="txtError" 
                       Foreground="#FF4747" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,15,0,0" 
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>