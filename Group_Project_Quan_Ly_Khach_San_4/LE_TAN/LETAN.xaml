<Window x:Class="Group_Project_Quan_Ly_Khach_San_4.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Lễ Tân - Hệ Thống Khách Sạn" Height="650" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid>
        <Image Source="pack://application:,,,/Dat_Phong/hotel.jpg" Stretch="UniformToFill"/>
        <Border Background="#CC2C3E50"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Background="#E62C3E50">
                <TextBlock Text="HỆ THỐNG LỄ TÂN" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,30,0,40" HorizontalAlignment="Center"/>

                <Button Content="Sơ đồ Phòng" Height="50" Margin="10,5" Background="#34495E" Foreground="White" BorderThickness="0"/>

                <Button Content="Thanh Toán" Height="50" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" Click="BtnThanhToan_Click"/>
                <Button Content="Danh sách đặt phòng" Height="50" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" Click="Btndsdt_Click"/>

                <Separator Margin="15,20" Background="#7F8C8D"/>

                <Button Content="Đăng xuất" Height="45" Margin="15,5" Background="#E74C3C" Foreground="White" BorderThickness="0" Click="BtnDangXuat_Click"/>
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#B3FFFFFF" Padding="20" CornerRadius="0,0,10,10" Margin="0,0,0,10">
                    <DockPanel>
                        <TextBlock Text="Sơ đồ Phòng" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2C3E50"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Rectangle Width="12" Height="12" Fill="#2ECC71" Margin="15,0,5,0"/>
                            <TextBlock Text="Phòng Trống" VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#F1C40F" Margin="15,0,5,0"/>
                            <TextBlock Text="Đã đặt" VerticalAlignment="Center"/>
                            <Rectangle Width="12" Height="12" Fill="#E74C3C" Margin="15,0,5,0"/>
                            <TextBlock Text="Đang ở" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="10" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="RoomList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="130" Height="110" Margin="8" Background="{Binding BackgroundColor}" Click="BtnRoom_Click" Foreground="White" BorderThickness="0" Opacity="0.9">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RoomName}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusText}" FontSize="10" Opacity="0.8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding CustomerName}" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" FontStyle="Italic"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</Window>